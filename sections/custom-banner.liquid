<div class="cb">

  <div class="cb__topbar">
    <span class="cb__brand">{{ section.settings.brand_text }}</span>
    <span class="cb__topbar-text">{{ section.settings.topbar_text }}</span>
    <a class="cb__yellow-btn" href="{{ section.settings.choose_gift_link }}">
      {{ section.settings.choose_gift_label }} <svg class="cb__arrow" width="26" height="12" viewBox="0 0 26 12" fill="none" aria-hidden="true"><path d="M0 6h23M18 1l6 5-6 5" stroke="currentColor" stroke-width="1.5"/></svg>
    </a>
  </div>

  <div class="cb__hero">
    {%- if section.settings.hero_top != blank -%}
      <img class="cb__hero-top" src="{{ section.settings.hero_top | image_url: width: 1600 }}" alt="">
    {%- else -%}
      <img class="cb__hero-top" src="{{ 'image.png' | asset_url }}" alt="">
    {%- endif -%}

    <div class="cb__hero-bottom">
      <div class="cb__hero-text">
        <h1 class="cb__title">{{ section.settings.title }}</h1>
        <div class="cb__subtitle">{{ section.settings.subtitle }}</div>
        <a class="cb__black-btn" href="{{ section.settings.shop_link }}">
          {{ section.settings.shop_label }} <svg class="cb__arrow" width="26" height="12" viewBox="0 0 26 12" fill="none" aria-hidden="true"><path d="M0 6h23M18 1l6 5-6 5" stroke="currentColor" stroke-width="1.5"/></svg>
        </a>
      </div>

      <div class="cb__hero-bottom-imgwrap">
        {%- if section.settings.hero_bottom != blank -%}
          <img class="cb__hero-bottom-img" src="{{ section.settings.hero_bottom | image_url: width: 1000 }}" alt="">
        {%- else -%}
          <img class="cb__hero-bottom-img" src="{{ 'image.png' | asset_url }}" alt="">
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="cb__announce">{{ section.settings.announce_text }}</div>
</div>

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700&display=swap');
  .cb { font-family: 'Jost', Arial, sans-serif; color: #0A0A0A; background: #ffffff; }

  .cb__topbar { display: flex; align-items: center; justify-content: space-between; gap: 20px; padding: 0 40px; height: 64px; border-bottom: 1px solid #e4e4e4; background: #EFEFEF; }
  .cb__brand { font-weight: 600; font-size: 18px; letter-spacing: .12em; color: #000; }
  .cb__topbar-text { flex: 1; text-align: center; font-size: 16px; font-weight: 400; color: #000; }
  .cb__yellow-btn { display: inline-flex; align-items: center; justify-content: center; gap: 20px; background: #F2E500; color: #000; text-decoration: none; height: 44px; padding: 0 22px; font-size: 16px; font-weight: 400; letter-spacing: 0; text-transform: uppercase; white-space: nowrap; }

  .cb__hero { background: #fff; }
  .cb__hero-top { display: block; width: 100%; aspect-ratio: 1440 / 390; object-fit: cover; object-position: center bottom; }
  .cb__hero-bottom { display: flex; align-items: stretch; justify-content: space-between; }
  .cb__hero-text { flex: 0 0 38.2%; padding: 0 20px 0 clamp(24px, 5vw, 67px); display: flex; flex-direction: column; justify-content: center; }
  .cb__hero-bottom-imgwrap { flex: 0 0 61.8%; width: 61.8%; aspect-ratio: 890 / 402; overflow: hidden; align-self: flex-start; }
  .cb__hero-bottom-img { width: 100%; height: 100%; object-fit: cover; object-position: left top; display: block; transform: scale(1.35); transform-origin: left top; }

  .cb__title { font-size: 66px; line-height: 1; font-weight: 500; margin: 0; letter-spacing: 0; color: #000; }
  .cb__subtitle { color: #000; font-size: 17x; line-height: 1.4; font-weight: 400; max-width: 483px; margin-top: 24px; }
  .cb__subtitle p { margin: 0; }
  .cb__black-btn { display: inline-flex; align-items: center; justify-content: center; gap: 20px; width: 220px; height: 50px; padding: 0 24px; margin-top: 40px; background: #0A0A0A; color: #fff; text-decoration: none; font-size: 16px; font-weight: 400; letter-spacing: 0; text-transform: uppercase; }

  .cb__yellow-btn, .cb__black-btn { transition: background-color .25s ease, color .25s ease; }
  .cb__yellow-btn:hover { background: #000000; color: #ffffff; }
  .cb__black-btn:hover { background: #F2E500; color: #000000; }
  .cb__arrow { flex: none; width: 26px; height: 12px; display: inline-block; transition: transform .28s ease; }
  .cb__yellow-btn:hover .cb__arrow, .cb__black-btn:hover .cb__arrow { transform: translateX(6px); }

  .cb__announce { background: #EFEFEF; height: 34px; display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 400; letter-spacing: 0; text-transform: uppercase; color: #000; }

  @media (prefers-reduced-motion: reduce) { .cb__arrow { transition: none; } }

  @media (max-width: 900px) {
    .cb__topbar { flex-wrap: wrap; height: auto; padding: 12px 20px; gap: 10px; }
    .cb__topbar-text { order: 3; flex-basis: 100%; text-align: left; }
    .cb__hero-bottom { flex-direction: column; align-items: stretch; }
    .cb__hero-text { flex-basis: auto; padding: 30px 24px 10px; text-align: center; align-items: center; }
    .cb__hero-bottom-imgwrap { width: 100%; flex-basis: auto; }
    .cb__title { font-size: 30px; }
    .cb__subtitle { font-size: 16px; margin-left: auto; margin-right: auto; }
    .cb__black-btn { margin-left: auto; margin-right: auto; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Custom Banner",
  "settings": [
    { "type": "text", "id": "brand_text", "label": "Brand name", "default": "TISSO VISON" },
    { "type": "text", "id": "topbar_text", "label": "Top bar text", "default": "Find the ideal gift for your loved ones." },
    { "type": "text", "id": "choose_gift_label", "label": "Yellow button label", "default": "Choose Gift" },
    { "type": "url", "id": "choose_gift_link", "label": "Yellow button link" },
    { "type": "image_picker", "id": "hero_top", "label": "Hero top image (1440x390)" },
    { "type": "image_picker", "id": "hero_bottom", "label": "Hero bottom-right image (890x402)" },
    { "type": "text", "id": "title", "label": "Hero title", "default": "The Gift Guide" },
    { "type": "richtext", "id": "subtitle", "label": "Hero subtitle", "default": "<p>Discover Joy: Your Ultimate Holiday Gift Destination. Explore our curated selection and find the perfect gifts to delight your loved ones this holiday season.</p>" },
    { "type": "text", "id": "shop_label", "label": "Shop button label", "default": "Shop Now" },
    { "type": "url", "id": "shop_link", "label": "Shop button link" },
    { "type": "text", "id": "announce_text", "label": "Announcement bar text", "default": "Sustainable, ethically made clothes in sizes XXS to 6XL" }
  ],
  "presets": [ { "name": "Custom Banner" } ]
}
{% endschema %}