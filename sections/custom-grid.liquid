<div class="cg">
  <h2 class="cg__heading">{{ section.settings.heading }}</h2>

  <div class="cg__grid">
    {%- for block in section.blocks -%}
      {%- assign product = all_products[block.settings.product] -%}
      {%- if product != blank -%}
        <article class="cg__tile" {{ block.shopify_attributes }}>
          <img class="cg__img" src="{{ product.featured_image | image_url: width: 700 }}" alt="{{ product.title | escape }}">
          <button class="cg__plus" type="button" data-handle="{{ product.handle }}" data-price="{{ product.price | money }}" aria-label="Quick view {{ product.title | escape }}">+</button>
          <script type="application/json" class="cg__data" data-handle="{{ product.handle }}">{{ product | json }}</script>
        </article>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<div class="cg__overlay" id="cgOverlay" hidden>
  <div class="cg__popup" role="dialog" aria-modal="true">
    <button class="cg__close" id="cgClose" type="button" aria-label="Close">&times;</button>
    <div class="cg__popup-top">
      <img class="cg__popup-img" id="cgImg" src="" alt="">
      <div>
        <h3 class="cg__popup-name" id="cgName"></h3>
        <div class="cg__popup-price" id="cgPrice"></div>
        <div class="cg__popup-desc" id="cgDesc"></div>
      </div>
    </div>
    <div class="cg__field">
      <div class="cg__label">Color</div>
      <div class="cg__swatches" id="cgColors"></div>
    </div>
    <div class="cg__field">
      <div class="cg__label">Size</div>
      <div class="cg__selectwrap">
        <select id="cgSize"><option value="">Choose your size</option></select>
        <span class="cg__chev">&#9662;</span>
      </div>
    </div>
    <button class="cg__addcart" id="cgAdd" type="button">Add to cart <span class="cg__arrow">&rarr;</span></button>
  </div>
</div>

{% style %}
  @import url('https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700&family=Lustria&display=swap');

  .cg { max-width: 1440px; margin: 0 auto; padding: 90px 51px; font-family: 'Jost', Arial, sans-serif; color: #000; }
  .cg__heading { font-family: 'Lustria', Georgia, serif; font-weight: 400; font-size: 36px; line-height: 1.2; margin: 0 0 30px; color: #000; }
  .cg__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .cg__tile { position: relative; aspect-ratio: 433 / 444; overflow: hidden; background: #eee; }
  .cg__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cg__plus { position: absolute; width: 34px; height: 34px; border-radius: 50%; background: rgba(248,248,248,0.9); border: 1px solid rgba(0,0,0,.12); color: #000; font-size: 20px; font-weight: 300; line-height: 1; display: grid; place-items: center; cursor: pointer; transition: transform .2s ease; }
  .cg__plus:hover { transform: scale(1.12); }
  .cg__tile:nth-child(1) .cg__plus { left: 59%; top: 54%; }
  .cg__tile:nth-child(2) .cg__plus { left: 82%; top: 50%; }
  .cg__tile:nth-child(3) .cg__plus { left: 60%; top: 18%; }
  .cg__tile:nth-child(4) .cg__plus { left: 70%; top: 16%; }
  .cg__tile:nth-child(5) .cg__plus { left: 49%; top: 23%; }
  .cg__tile:nth-child(6) .cg__plus { left: 74%; top: 37%; }

  .cg__overlay { position: fixed; inset: 0; background: rgba(0,0,0,.45); display: grid; place-items: center; padding: 20px; z-index: 9999; }
  .cg__overlay[hidden] { display: none; }
  .cg__popup { width: 320px; max-width: 100%; background: #fff; position: relative; padding: 32px 20px 20px; box-shadow: 0 2px 4px rgba(0,0,0,.2); }
  .cg__close { position: absolute; top: 12px; right: 14px; background: none; border: none; font-size: 20px; cursor: pointer; line-height: 1; }
  .cg__popup-top { display: flex; gap: 8px; align-items: flex-start; margin-bottom: 0px; }
  .cg__popup-img { width: 120px; height: 140px; flex: none; object-fit: cover; background: #eee; }
  .cg__popup-name { font-family: 'Jost', sans-serif; font-weight: 300; font-size: 16px; line-height: 1; margin: 0; }
  .cg__popup-price { font-family: 'Lustria', Georgia, serif; font-weight: 400; font-size: 16px; margin: 10px 0 0; }
  .cg__popup-desc { font-family: 'Jost', sans-serif; font-weight: 300; font-size: 14px; line-height: 1; letter-spacing: -0.01em; color: #000; margin: 0; }
  .cg__field { margin-top: 0px; }
  .cg__label { font-family: 'Jost', sans-serif; font-weight: 400; font-size: 14px; color: #333; margin-bottom: 0px; }
  .cg__swatches { display: flex; border: 1px solid #000; }
  .cg__swatch { position: relative; flex: 1; display: flex; align-items: center; padding: 8px 8px 8px 14px; font-family: 'Jost', sans-serif; font-size: 18px; font-weight: 400; letter-spacing: -0.02em; text-transform: capitalize; background: none; border: none; text-align: left; cursor: pointer; color: #000; }
  .cg__swatch-bar { position: absolute; left: 0; top: 0; bottom: 0; width: 6px; border: 0.5px solid rgba(0,0,0,.4); }
  .cg__swatch + .cg__swatch { border-left: 1px solid #000; }
  .cg__swatch.is-selected { background: #000; color: #fff; }
  .cg__selectwrap { position: relative; border: 1px solid #000; }
  .cg__selectwrap select { appearance: none; -webkit-appearance: none; border: none; background: none; font-family: 'Jost', sans-serif; font-size: 16px; letter-spacing: -0.02em; padding: 10px 10px 10px 10px; width: 100%; cursor: pointer; color: #000; text-align: left; text-align-last: left; }
  .cg__selectwrap select.cg--chosen { text-align: center; text-align-last: center; padding: 12px 52px; }
  .cg__selectwrap select option { text-align: center; }
  .cg__chev { position: absolute; right: 0; top: 0; bottom: 0; width: 44px; border-left: 1px solid #000; display: grid; place-items: center; pointer-events: none; }
  .cg__addcart { display: flex; align-items: center; justify-content: center; gap: 30px; width: 100%; background: #000; color: #fff; border: none; cursor: pointer; font-family: 'Jost', sans-serif; font-size: 16px; font-weight: 400; text-transform: uppercase; padding: 14px; margin-top: 30px; }
  .cg__addcart .cg__arrow { transition: transform .28s ease; }
  .cg__addcart:hover .cg__arrow { transform: translateX(10px); }

  @media (max-width: 900px) {
    .cg { padding: 48px 20px; }
    .cg__grid { grid-template-columns: repeat(2, 1fr); gap: 6px; }
    .cg__heading { font-size: 24px; }
    .cg__popup-top { flex-direction: column; }
    .cg__popup-img { width: 100%; height: 200px; }
  }
{% endstyle %}

<script>
(function () {
  var overlay = document.getElementById('cgOverlay');
  if (!overlay) return;

  var els = {
    close: document.getElementById('cgClose'), img: document.getElementById('cgImg'),
    name: document.getElementById('cgName'), price: document.getElementById('cgPrice'),
    desc: document.getElementById('cgDesc'), colors: document.getElementById('cgColors'),
    size: document.getElementById('cgSize'), add: document.getElementById('cgAdd')
  };

  var product = null, colorIdx = -1, sizeIdx = -1, selectedColor = null;

  // Variant id of the Soft Winter Jacket — auto-added when Black + M is chosen
  var JACKET_ID = {% if all_products['dark-winter-jacket'] != blank %}{{ all_products['dark-winter-jacket'].selected_or_first_available_variant.id }}{% else %}null{% endif %};

  // Open the popup from any "+" button
  document.querySelectorAll('.cg__plus').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var handle = btn.getAttribute('data-handle');
      var dataEl = document.querySelector('.cg__data[data-handle="' + handle + '"]');
      product = JSON.parse(dataEl.textContent);
      openPopup(btn.getAttribute('data-price'));
    });
  });

  function openPopup(formattedPrice) {
    colorIdx = product.options.findIndex(function (o) { return o.toLowerCase().indexOf('color') > -1; });
    sizeIdx  = product.options.findIndex(function (o) { return o.toLowerCase().indexOf('size') > -1; });
    els.img.src = product.featured_image || '';
    els.name.textContent = product.title;
    els.price.textContent = formattedPrice;
    els.desc.innerHTML = product.description || '';
    buildColors();
    buildSizes();
    overlay.hidden = false;
  }

  function uniqueValues(idx) {
    var seen = [];
    product.variants.forEach(function (v) {
      var val = v.options[idx];
      if (val && seen.indexOf(val) === -1) seen.push(val);
    });
    return seen;
  }

  function buildColors() {
    var COLORS = { white:'#ffffff', black:'#000000', blue:'#0d499f', red:'#b20f36', grey:'#afafb7', gray:'#afafb7', green:'#2e7d32', orange:'#e8722a', yellow:'#f2e500' };
    els.colors.innerHTML = ''; selectedColor = null;
    if (colorIdx === -1) return;
    uniqueValues(colorIdx).forEach(function (color) {
      var b = document.createElement('button');
      b.type = 'button'; b.className = 'cg__swatch';
      var bar = document.createElement('span');
      bar.className = 'cg__swatch-bar';
      bar.style.background = COLORS[String(color).toLowerCase()] || '#cccccc';
      var label = document.createElement('span');
      label.textContent = color;
      b.appendChild(bar); b.appendChild(label);
      b.addEventListener('click', function () {
        selectedColor = color;
        Array.prototype.forEach.call(els.colors.children, function (c) { c.classList.remove('is-selected'); });
        b.classList.add('is-selected');
      });
      els.colors.appendChild(b);
    });
  }

  function buildSizes() {
    els.size.innerHTML = '<option value="">Choose your size</option>';
    els.size.classList.remove('cg--chosen');
    if (sizeIdx === -1) return;
    uniqueValues(sizeIdx).forEach(function (size) {
      var o = document.createElement('option');
      o.value = size; o.textContent = size; els.size.appendChild(o);
    });
  }

  function findVariant(color, size) {
    return product.variants.find(function (v) {
      var cOk = colorIdx === -1 || v.options[colorIdx] === color;
      var sOk = sizeIdx === -1 || v.options[sizeIdx] === size;
      return cOk && sOk;
    });
  }

  function addToCart(id, qty) {
    return fetch('/cart/add.js', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [{ id: id, quantity: qty || 1 }] })
    });
  }

  els.add.addEventListener('click', function () {
    var size = els.size.value;
    if ((colorIdx !== -1 && !selectedColor) || (sizeIdx !== -1 && !size)) {
      alert('Please choose a colour and size.'); return;
    }
    var variant = findVariant(selectedColor, size);
    if (!variant) { alert('Sorry, that combination is unavailable.'); return; }

    addToCart(variant.id).then(function () {
      // Bundle rule: Black + M (Medium) also adds the Soft Winter Jacket
      var isBlack = selectedColor && selectedColor.toLowerCase() === 'black';
      var isMedium = size && size.toLowerCase() === 'm';
      if (isBlack && isMedium && JACKET_ID) { return addToCart(JACKET_ID); }
    }).then(function () {
      window.location.href = '/cart';
    }).catch(function () { alert('Something went wrong adding to cart.'); });
  });

  function close() { overlay.hidden = true; }
  els.close.addEventListener('click', close);
  els.size.addEventListener('change', function () { els.size.classList.toggle('cg--chosen', !!els.size.value); });
  overlay.addEventListener('click', function (e) { if (e.target === overlay) close(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') close(); });
})();
</script>

{% schema %}
{
  "name": "Custom Grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Tisso vison in the wild" }
  ],
  "blocks": [
    { "type": "product", "name": "Product", "settings": [
      { "type": "product", "id": "product", "label": "Product" }
    ]}
  ],
  "max_blocks": 6,
  "presets": [
    { "name": "Custom Grid", "blocks": [
      {"type":"product"},{"type":"product"},{"type":"product"},
      {"type":"product"},{"type":"product"},{"type":"product"}
    ]}
  ]
}
{% endschema %}